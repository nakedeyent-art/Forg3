# API
# Leave blank for local web dev so Vite proxies /api to the Express server.
# For iOS/Android builds, point this at your deployed HTTPS API.
VITE_API_BASE_URL=
PORT=4127
FORG3_DATA_FILE=./data/forg3-store.json
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,capacitor://localhost,https://localhost
JSON_BODY_LIMIT=16mb
MAX_PDF_BYTES=10485760

# Firebase Auth is optional. When all Firebase values are present, the Google
# and Apple buttons use Firebase providers. Otherwise they run in local demo mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin is required for production API authentication. Prefer
# GOOGLE_APPLICATION_CREDENTIALS in deployed environments, or provide either a JSON
# service account payload or the individual service account fields below.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local development only. Used to sign NODE_ENV!=production dev auth tokens.
DEV_AUTH_SECRET=

# Production persistence. The development JSON store refuses to start in
# NODE_ENV=production unless explicitly overridden for emergency migration tooling.
DATABASE_URL=
BLOB_STORAGE_PROVIDER=s3
BLOB_STORAGE_BUCKET=
BLOB_STORAGE_KMS_KEY_ID=
ALLOW_FILE_STORE_IN_PRODUCTION=false

# Billing
# The local build uses demo billing. Production should use native StoreKit /
# Google Play Billing and call /api/subscription/verify server-side.
VITE_BILLING_MODE=demo
# Default usage fee for the $12/year pay-per-signature plan.
PAY_PER_SIGNATURE_FEE_CENTS=99

# Product/legal decision required before production:
# block_when_inactive prevents signers from completing after owner lapse.
# bill_metered allows metered-plan signers to complete and records usage.
SIGNING_ENTITLEMENT_POLICY=block_when_inactive
