# API
# Leave blank for local web dev so Vite proxies /api to the Express server.
# For iOS/Android builds, point this at your deployed HTTPS API.
VITE_API_BASE_URL=
PORT=4127
FORG3_DATA_FILE=./data/forg3-store.json
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,capacitor://localhost,https://localhost
JSON_BODY_LIMIT=16mb
MAX_PDF_BYTES=10485760

# Public web app URL used inside signer emails.
# Example: https://sign.forg3.app
PUBLIC_SIGNING_BASE_URL=

# Firebase Auth is optional. When all Firebase values are present, the Google
# and Apple buttons use Firebase providers. VITE_* values are bundled at build
# time; FIREBASE_WEB_* values are served by the API at runtime so deployed
# clients can enable provider buttons without another native rebuild.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_WEB_APP_ID=

# Firebase Admin is required for production API authentication. Prefer
# GOOGLE_APPLICATION_CREDENTIALS in deployed environments, or provide either a JSON
# service account payload or the individual service account fields below.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local development only. Used to sign NODE_ENV!=production dev auth tokens.
DEV_AUTH_SECRET=
APP_AUTH_SECRET=
DEVICE_TRUST_SECRET=
FORG3_DEVICE_2FA=true
FORG3_MFA_CODE_TTL_MINUTES=10
FORG3_TRUSTED_DEVICE_DAYS=30
# Optional store-review access. Set only in deployed review environments.
# This gives Apple/Google reviewers a reusable six-digit code without requiring
# inbox access; pair the email with FORG3_CREATOR_EMAILS for full sender access.
FORG3_REVIEW_ACCESS_EMAIL=
FORG3_REVIEW_ACCESS_CODE=
# Creator accounts bypass paid entitlement and are the only unlimited accounts
# besides the highest subscription tier. Use a comma-separated server-side list.
FORG3_CREATOR_EMAILS=
# Optional local demo identity. Set this to the same email as one creator entry
# when testing creator unlimited access without Firebase.
VITE_DEV_OWNER_EMAIL=
VITE_DEV_OWNER_NAME=

# Production persistence. The development JSON store refuses to start in
# NODE_ENV=production unless explicitly overridden for emergency migration tooling.
DATABASE_URL=
BLOB_STORAGE_PROVIDER=s3
BLOB_STORAGE_BUCKET=
BLOB_STORAGE_KMS_KEY_ID=
ALLOW_FILE_STORE_IN_PRODUCTION=false

# Billing
# The local build uses demo billing. Production iOS/Android builds must use
# native StoreKit / Google Play Billing, then call /api/subscription/verify.
VITE_BILLING_MODE=demo
# Set true for paid iOS/Android production launches so the server refuses to
# boot unless Apple and Google store verification credentials are configured.
FORG3_REQUIRE_STORE_BILLING=false
# Default usage fee for the $12/year pay-per-signature plan.
PAY_PER_SIGNATURE_FEE_CENTS=99
# App Store Server API.
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
APPLE_APP_STORE_PRIVATE_KEY_BASE64=
APPLE_APP_STORE_PRIVATE_KEY_FILE=
APPLE_APP_STORE_PRIVATE_KEY_PATH=
APPLE_APP_STORE_BUNDLE_ID=com.forg3.sign
APPLE_APP_STORE_ENVIRONMENT=sandbox
APP_STORE_VERSION=1.0
APP_STORE_REVIEW_FIRST_NAME=
APP_STORE_REVIEW_LAST_NAME=
APP_STORE_REVIEW_EMAIL=st@nak3deye.com
APP_STORE_REVIEW_PHONE=
# Must be set only after the account owner/legal reviewer confirms the export
# compliance answer in App Store Connect.
APP_STORE_EXPORT_COMPLIANCE_CONFIRMED=false
# Google Play Developer API / RTDN.
GOOGLE_PLAY_PACKAGE_NAME=com.forg3.sign
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_RTDN_VERIFICATION_TOKEN=
BILLING_WEBHOOK_TOKEN=

# Product/legal decision required before production:
# block_when_inactive prevents signers from completing after owner lapse.
# bill_metered allows metered-plan signers to complete and records usage.
SIGNING_ENTITLEMENT_POLICY=block_when_inactive

# Outbound delivery.
# EMAIL_PROVIDER=microsoft_graph sends mail through Microsoft 365 / Graph.
# EMAIL_PROVIDER=resend sends mail through Resend.
EMAIL_PROVIDER=
RESEND_API_KEY=
FORG3_EMAIL_FROM=
FORG3_EMAIL_REPLY_TO=
# Set true only when the configured provider is authorized to send as each
# signed-in owner email. Otherwise Forg3 uses the configured sender mailbox and
# places the owner email in Reply-To plus the email body.
EMAIL_SEND_AS_OWNER=false
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_SENDER=
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS=true
MICROSOFT_GRAPH_USE_FROM_ALIAS=false

# Security hardening (Phase 10).
# 32-byte key (hex or base64) enabling AES-256-GCM encryption at rest for
# uploaded and sealed PDFs. Required in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FORG3_OBJECT_ENCRYPTION_KEY=
# Emergency escape hatch only; never enable for a real deployment.
ALLOW_PLAINTEXT_OBJECTS_IN_PRODUCTION=false
# Abuse protection on login/2FA code endpoints (per IP per 15 minutes).
FORG3_AUTH_CODE_LIMIT=10
FORG3_AUTH_VERIFY_LIMIT=40
# Minimum seconds between code emails per account+device.
FORG3_CODE_RESEND_COOLDOWN_SECONDS=30

# Deployment (see docs/DEPLOYMENT.md).
# Bind address/port. Production defaults to 0.0.0.0; local dev to 127.0.0.1.
HOST=
PORT=4127
# Postgres connection string. Required in production; empty uses local files.
DATABASE_URL=
# disable | no-verify | require. Leave empty for automatic behavior.
DATABASE_SSL=
DATABASE_POOL_SIZE=5
# Reverse-proxy hops in front of the app (client IPs for rate limiting).
TRUST_PROXY_HOPS=
# Public HTTPS origin used inside signing-link emails.
PUBLIC_SIGNING_BASE_URL=
# Extra allowed browser origins, comma separated (same-origin needs none).
CORS_ORIGINS=
# docker-compose only: password for the bundled Postgres service.
POSTGRES_PASSWORD=
